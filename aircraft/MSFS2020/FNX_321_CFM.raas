        "CenterOnSpace": true,
        "BrightnessVariable": "[L:N_DISPLAY_BRIGHTNESS_FI|double] * 100",
        "TerrainEnabled": "[L:I_MIP_GPWS_TERRAIN_ON_ND_FO_L|double] > 0",
        "MessageCategoryFilter": 1,
